[
  {
    "Namespace": "",
    "Key": "AA14643C4149CDB1764B47BD40C8B543",
    "Hash": 758888731,
    "SourceString": "So, What'll it be today?",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "F6A1CFF34306A6DA898106A7DFFAFB3E",
    "Hash": 3344002344,
    "SourceString": "Nothing right now...",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "B07090B840E3D6F603770AB8C68AD983",
    "Hash": 3196878164,
    "SourceString": "Looking to trade...",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "F936BBA24C4587F462DFE4B20D86076A",
    "Hash": 356653515,
    "SourceString": "Got any good gossip?",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "F5CA37484778240F3025B88361246A93",
    "Hash": 4142169930,
    "SourceString": "Nope, that's all I got to share today...",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "BA4199444BFFF2FF15DA2E8925CB2096",
    "Hash": 650405600,
    "SourceString": "...",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "484BEBFD4CB311634070E89C2C677C5F",
    "Hash": 404200910,
    "SourceString": "I've heard wind that the Insurrection is trying to find a route up north at the Dead End.",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "CE0FF852402189EA15E4A7B867D6DA3D",
    "Hash": 843388076,
    "SourceString": "There is a tunnel up there, but its not the one they think...",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "31F9EE72499B8467313110843927EC26",
    "Hash": 3108632399,
    "SourceString": "Interesting...",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "ED5E8E5D43B7773FDB25E3B9FD3CC4DB",
    "Hash": 1765079270,
    "SourceString": "My buddy, Big Iron, has a gun shop down in South Bend.",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "C3064DC2482BA2354DDE14A825B12DF5",
    "Hash": 1654203634,
    "SourceString": "He can customize all sorts of weapons, even electro-kinetic ones! ",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "534EEA934BB7500D156089BA955AC983",
    "Hash": 796545239,
    "SourceString": "Electro-waht?",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "542853934F077DEDADC446B54AD7A599",
    "Hash": 1041515156,
    "SourceString": "There's this big facility in the northern zone called The Wall.",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "05249E9C472ED2F15181D39C8A314AE9",
    "Hash": 945149836,
    "SourceString": "I've been told it houses unique and valuable materials from before the Threshold. ",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "9AA820BC43884F81A460909A4924F7D3",
    "Hash": 483242602,
    "SourceString": "Maybe I'll check it out..",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "87DF906249CE9E9B99FEADB12C59A0E6",
    "Hash": 907837241,
    "SourceString": "Word is old Mama Roach and her boys pulled off a major heist not too long ago..",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "831FA4B949A9AA4311E46E97483EC545",
    "Hash": 743366316,
    "SourceString": "They've been super tight-lipped about what they stole.",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "57A0266D446079B51C1795A648084C22",
    "Hash": 2740950474,
    "SourceString": "Hmm...",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "4C89E9F74AD22DED97FDAAB318CA5620",
    "Hash": 3651223809,
    "SourceString": "Apparently Doc Mosby is having trouble with a missing science team he sent out.",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "2BDF5FB34ECFE27D52174C945399257D",
    "Hash": 563490829,
    "SourceString": "You should go ask about it, might be good work.",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "098EA2B24F7275B7F989E58B791B8AFF",
    "Hash": 2806075840,
    "SourceString": "My buddies in the black market let me in on something.",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "E39A19814012D761E6F2EE856B30991E",
    "Hash": 2177486297,
    "SourceString": "The Broker's been buying up artifacts at a premium; high volumes too...",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "808D0C854CEFE4EE6160D2B610D4C934",
    "Hash": 3816825735,
    "SourceString": "Might be a good way to score some cash.",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "72239C144B7D377FBD4DB7A1DD706BDD",
    "Hash": 2908474747,
    "SourceString": "I've been poking around by the beach lately, found an old boat.",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "29E722864D4FE3B3EB05DEBACFF8E7E0",
    "Hash": 718089264,
    "SourceString": "It's not in too bad a shape; might even be sea-worthy.",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "2F00C7D5437EF348238160960AF9F093",
    "Hash": 571113064,
    "SourceString": "I wouldn't try taking it out of the zone though; at least not without a good map...",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "9E46C00C4B3FA3AB3451CDA08E08A917",
    "Hash": 171510430,
    "SourceString": "I'll keep it in mind...",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "0F9ABCD74F88B140C65590A8EE6DEF82",
    "Hash": 3079192446,
    "SourceString": "The revolution's been working on a big project lately.",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "66E9C41D46A6B202466534B5D5B8CC65",
    "Hash": 3490391475,
    "SourceString": "It involves a lot of welders and railway engineers apparently...",
    "LocalizedString": ""
  },
  {
    "Namespace": "",
    "Key": "5768F7D74C55BC8A844B59A2020851AA",
    "Hash": 193720107,
    "SourceString": "Strange..",
    "LocalizedString": ""
  }
]